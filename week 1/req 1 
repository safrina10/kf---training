pin = 1075
minibalance = 5000
balance = 10000
chance = 0
withlimit = 20000
transcation = ""

while chance < 3:
    a = int(input("Enter the PIN: "))

    if a == pin:
        print("Proceed")
        break
    else:
        chance += 1
        print("Wrong PIN")

if chance == 3:
    print("Card Blocked")

else:
    while True:

        click = input("1.Withdraw 2.Deposit 3.Ministatement 4.Exit : ")

        match click:

            case "1":
                amt = int(input("Enter amount: "))

                if amt <= balance:
                    balance -= amt
                    transcation += f"Withdrawn {amt}\n"

                    print("Withdrawal successful")
                    print(f"Balance: {balance}")

                elif amt > withlimit:
                    print("Daily limit exceeded")

                else:
                    print("Insufficient balance")

            case "2":
                amtn = int(input("Enter amount: "))

                if amtn > 0:
                    balance += amtn
                    transcation += f"Deposited {amtn}\n"

                    print(f"Amount added. Balance: {balance}")

                else:
                    print("Enter positive amount")

            case "3":
                print("------ MINI STATEMENT ------")
                print(transcation)
                print(f"Balance: {balance}")

            case "4":
                print("Thank you, give us rating")
                break